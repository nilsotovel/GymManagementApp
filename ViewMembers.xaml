<Page x:Class="GymManagementApp.ViewMembers"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GymManagementApp"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="View Members">

    <Grid Background="#1E272E">
        <StackPanel Margin="40">
            <TextBlock Text="GYM MEMBER DIRECTORY" 
                       FontSize="24" 
                       FontWeight="ExtraBold" 
                       Foreground="#34E7E4" 
                       Margin="0,0,0,25" 
                       HorizontalAlignment="Center"/>

            <Border Background="#2F3542" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="5,0">
                        <TextBlock Text="MEMBER ID:" Foreground="White" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtSearchID" Height="35" VerticalContentAlignment="Center" Padding="10,0" Background="White"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0">
                        <TextBlock Text="FIRST NAME:" Foreground="White" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtSearchFirstName" Height="35" VerticalContentAlignment="Center" Padding="10,0" Background="White"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="5,0">
                        <TextBlock Text="LAST NAME:" Foreground="White" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtSearchLastName" Height="35" VerticalContentAlignment="Center" Padding="10,0" Background="White"/>
                    </StackPanel>

                    <Button Grid.Column="3" Content="SEARCH" 
                            Click="BtnSearch_Click" 
                            Width="100" Height="35" 
                            Margin="10,16,5,0" 
                            Background="#3498DB" 
                            Foreground="White" 
                            FontWeight="Bold"
                            VerticalAlignment="Bottom"/>
                </Grid>
            </Border>

            <Border Background="#2F3542" CornerRadius="10" Padding="10">
                <DataGrid x:Name="dgMembers"
                          Height="300"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="#2F3542"
                          AlternatingRowBackground="#34495E"
                          Foreground="White"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#34E7E4"
                          HeadersVisibility="Column"
                          ColumnHeaderHeight="40">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#2C3E50"/>
                            <Setter Property="Foreground" Value="#34E7E4"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#34E7E4"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"          Binding="{Binding MemberID}"   Width="55"/>
                        <DataGridTextColumn Header="First Name"  Binding="{Binding FirstName}"  Width="*"/>
                        <DataGridTextColumn Header="Last Name"   Binding="{Binding LastName}"   Width="*"/>
                        <DataGridTextColumn Header="Phone"       Binding="{Binding Phone}"      Width="110"/>
                        <DataGridTextColumn Header="Type"        Binding="{Binding MemberType}" Width="80"/>
                        <DataGridTextColumn Header="Join Date"   Binding="{Binding JoinDate,   StringFormat={}{0:yyyy-MM-dd}}" Width="100"/>
                        <DataGridTextColumn Header="Expiry Date" Binding="{Binding ExpiryDate, StringFormat={}{0:yyyy-MM-dd}}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </Grid>
</Page>