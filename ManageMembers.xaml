<Page x:Class="GymManagementApp.ManageMembers"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GymManagementApp"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Manage Members">

    <Grid Background="#1E272E">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40">
                <TextBlock Text="GYM MEMBERSHIP MANAGEMENT" 
                           FontSize="24" 
                           FontWeight="ExtraBold" 
                           Foreground="#34E7E4" 
                           Margin="0,0,0,25"
                           HorizontalAlignment="Center"/>

                <Border Background="#2F3542" CornerRadius="10" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Member ID (Admin Only):" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtMemberID" Height="35" VerticalContentAlignment="Center" Background="White" Margin="0,0,0,15" Padding="10,0"/>

                        <TextBlock Text="Member Name:" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtMemberName" Height="35" VerticalContentAlignment="Center" Background="White" Margin="0,0,0,15" Padding="10,0"/>

                        <TextBlock Text="Phone Number:" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtPhone" Height="35" VerticalContentAlignment="Center" Background="White" Margin="0,0,0,15" Padding="10,0"/>

                        <TextBlock Text="Membership Type:" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
                        <ComboBox x:Name="cbMemberType" Height="35" VerticalContentAlignment="Center" Margin="0,0,0,30">
                            <ComboBoxItem Content="Monthly"/>
                            <ComboBoxItem Content="Annual"/>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="ADD" Click="BtnAdd_Click" Width="100" Height="40" Margin="0,0,10,0" Background="#05C46B" Foreground="White" FontWeight="Bold"/>

                            <Button Content="UPDATE" Click="BtnUpdate_Click" Width="100" Height="40" Margin="0,0,10,0" Background="#3498DB" Foreground="White" FontWeight="Bold"/>

                            <Button Content="DELETE" Click="BtnDelete_Click" Width="100" Height="40" Margin="0,0,10,0" Background="#FF3F34" Foreground="White" FontWeight="Bold"/>

                            <Button Content="RESET" Click="BtnReset_Click" Width="100" Height="40" Background="#7F8C8D" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="CLICK A ROW TO FILL THE FORM"
                           Foreground="#7F8C8D"
                           FontSize="11"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,8"/>

                <Border Background="#2F3542" CornerRadius="10" Padding="10">
                    <DataGrid x:Name="dgManageMembers"
                              Height="250"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="DgManageMembers_SelectionChanged"
                              Background="Transparent"
                              BorderThickness="0"
                              RowBackground="#2F3542"
                              AlternatingRowBackground="#34495E"
                              Foreground="White"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#34E7E4"
                              HeadersVisibility="Column"
                              ColumnHeaderHeight="40">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#2C3E50"/>
                                <Setter Property="Foreground" Value="#34E7E4"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10,0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                <Setter Property="BorderBrush" Value="#34E7E4"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"          Binding="{Binding MemberID}"   Width="55"/>
                            <DataGridTextColumn Header="First Name"  Binding="{Binding FirstName}"  Width="*"/>
                            <DataGridTextColumn Header="Last Name"   Binding="{Binding LastName}"   Width="*"/>
                            <DataGridTextColumn Header="Phone"       Binding="{Binding Phone}"      Width="110"/>
                            <DataGridTextColumn Header="Type"        Binding="{Binding MemberType}" Width="80"/>
                            <DataGridTextColumn Header="Join Date"   Binding="{Binding JoinDate,   StringFormat={}{0:yyyy-MM-dd}}" Width="100"/>
                            <DataGridTextColumn Header="Expiry Date" Binding="{Binding ExpiryDate, StringFormat={}{0:yyyy-MM-dd}}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>