<Window x:Class="GymManagementApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gym Management System" 
        Height="650" 
        Width="1000"
        Background="#1E272E" 
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <Border DockPanel.Dock="Top" 
                Background="#2C3E50" 
                BorderBrush="#34E7E4" 
                BorderThickness="0,0,0,2">

            <Grid>
                <TextBlock Text="GYM PRO ADMIN" 
                           Foreground="#34E7E4" 
                           VerticalAlignment="Center" 
                           FontWeight="Bold" 
                           FontSize="18"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                    <Button Content="VIEW MEMBERS" 
                            Click="NavView_Click" 
                            Width="140" 
                            Height="35" 
                            Margin="5,0" 
                            Background="#34495E" 
                            Foreground="White" 
                            FontWeight="Bold" 
                            Cursor="Hand"/>

                    <Button Content="MANAGE" 
                            Click="NavManage_Click" 
                            Width="140" 
                            Height="35" 
                            Margin="5,0" 
                            Background="#34495E" 
                            Foreground="White" 
                            FontWeight="Bold" 
                            Cursor="Hand"/>

                    <Button Content="LOGOUT/EXIT" 
                            Click="BtnExit_Click" 
                            Width="140" 
                            Height="35" 
                            Margin="25,0,5,0" 
                            Background="#FF3F34" 
                            Foreground="White" 
                            FontWeight="Bold" 
                            Cursor="Hand"/>

                </StackPanel>
            </Grid>
        </Border>

        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        
    </DockPanel>
</Window>